# https://ghostty.org/docs/config
# https://github.com/ghostty-org/ghostty/blob/main/src/config/Config.zig
# Style
font-family = "TX-02"
font-family = 500
font-size = 14
background-opacity = 1

# Window
window-padding-x = 15
window-padding-y = 10
window-inherit-working-directory = true

# Cursor
cursor-style = block

# Interaction
app-notifications = no-clipboard-copy
copy-on-select = clipboard
clipboard-paste-protection = true
mouse-hide-while-typing = true
confirm-close-surface = false


# Shell integration
shell-integration = fish

# Keybindings
keybind = ctrl+shift+r=reload_config
 
# Theme 
# https://ghostty.org/docs/config/reference#theme
# Location: /usr/share/ghostty/themes
# Palette cheat sheet: https://www.ditig.com/publications/256-colors-cheat-sheet
# Font feature info: https://fontdrop.info
theme=GitHub Dark
background-opacity=0.99
background-blur=true

